{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ACCESSFLOW_ENVIRONMENT": "internal",
        "EXPO_PUBLIC_ACCESSFLOW_RELEASE_CHANNEL": "preview",
        "EXPO_PUBLIC_ACCESSFLOW_DISTRIBUTION_CHANNEL": "internal",
        "EXPO_PUBLIC_ACCESSFLOW_MANAGED_DEVICE_MODE": "shared-guard"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ACCESSFLOW_ENVIRONMENT": "production",
        "EXPO_PUBLIC_ACCESSFLOW_RELEASE_CHANNEL": "production",
        "EXPO_PUBLIC_ACCESSFLOW_DISTRIBUTION_CHANNEL": "play-store",
        "EXPO_PUBLIC_ACCESSFLOW_MANAGED_DEVICE_MODE": "organization-owned"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
