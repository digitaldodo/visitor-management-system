EXPO_PUBLIC_ACCESSFLOW_API_BASE_URL=https://accessflow-api-goww.onrender.com/api/v1
EXPO_PUBLIC_ACCESSFLOW_EXPO_PROJECT_ID=695a77a0-f60f-481f-93cd-23ebfb4c256b
EXPO_PUBLIC_ACCESSFLOW_ENVIRONMENT=production
EXPO_PUBLIC_ACCESSFLOW_RELEASE_CHANNEL=production
EXPO_PUBLIC_ACCESSFLOW_DISTRIBUTION_CHANNEL=play-store
EXPO_PUBLIC_ACCESSFLOW_INACTIVITY_LOCK_MS=300000
EXPO_PUBLIC_ACCESSFLOW_SCREENSHOT_PROTECTION=true
EXPO_PUBLIC_ACCESSFLOW_TLS_PINNING_ENABLED=true
EXPO_PUBLIC_ACCESSFLOW_TLS_PINNING_ENFORCED=true
EXPO_PUBLIC_ACCESSFLOW_TLS_INCLUDE_SUBDOMAINS=true
# Comma-separated sha256 public-key pins. Keep at least one backup pin for certificate rotation.
EXPO_PUBLIC_ACCESSFLOW_TLS_PUBLIC_KEY_PINS=
EXPO_PUBLIC_ACCESSFLOW_TLS_BACKUP_PUBLIC_KEY_PINS=
EXPO_PUBLIC_ACCESSFLOW_OBSERVABILITY_ENABLED=true
EXPO_PUBLIC_ACCESSFLOW_TELEMETRY_FLUSH_MS=60000
EXPO_PUBLIC_ACCESSFLOW_FIREBASE_ENABLED=true
EXPO_PUBLIC_ACCESSFLOW_FIREBASE_MESSAGING_ENABLED=true
EXPO_PUBLIC_ACCESSFLOW_FIREBASE_CRASHLYTICS_ENABLED=true
EXPO_PUBLIC_ACCESSFLOW_FIREBASE_ANALYTICS_ENABLED=true
# Path to the Android google-services.json used by EAS/prebuild. Do not commit the file unless your release policy allows it.
ACCESSFLOW_FIREBASE_ANDROID_GOOGLE_SERVICES_FILE=./google-services.json
EXPO_PUBLIC_ACCESSFLOW_OTA_ENABLED=true
EXPO_PUBLIC_ACCESSFLOW_UPDATE_CHECK_MS=900000
EXPO_PUBLIC_ACCESSFLOW_ROLLOUT_COHORT=stable
EXPO_PUBLIC_ACCESSFLOW_SECURITY_POLL_MS=20000
EXPO_PUBLIC_ACCESSFLOW_EMPLOYEE_POLL_MS=35000
EXPO_PUBLIC_ACCESSFLOW_ADMIN_POLL_MS=45000
EXPO_PUBLIC_ACCESSFLOW_STALE_CACHE_MS=120000
EXPO_PUBLIC_ACCESSFLOW_MANAGED_DEVICE_MODE=personal
EXPO_PUBLIC_ACCESSFLOW_KIOSK_READY=false
EXPO_PUBLIC_ACCESSFLOW_BRANDING_READY=false
EXPO_PUBLIC_ACCESSFLOW_DEFAULT_LOGO_URL=
