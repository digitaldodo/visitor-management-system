{
  "expo": {
    "name": "AccessFlow Mobile",
    "owner": "anshmrns-organization",
    "slug": "accessflow",
    "version": "1.5.0",
    "scheme": "accessflow",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09111E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.accessflow.mobile",
      "versionCode": 22,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.WRITE_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09111E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-updates",
      "expo-notifications",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AccessFlow Mobile to scan badges and capture verification photos.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AccessFlow Mobile to select a profile photo for your employee credential.",
          "cameraPermission": "Allow AccessFlow Mobile to capture a profile photo for your employee credential."
        }
      ],
      "expo-local-authentication",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "f6f82d40-344d-4ae9-93bf-a58c869db1ac"
      },
      "accessflowReleaseChannel": "production",
      "accessflowDistributionChannel": "play-store"
    }
  }
}
