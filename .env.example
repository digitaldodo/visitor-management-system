MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/visitor_management
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
JWT_ISSUER=visitor-management
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7
CORS_ALLOWED_ORIGINS=https://accessflow-web.onrender.com
SUPER_ADMIN_NAME=AccessFlow Owner
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=CLOUD_NAME
CLOUDINARY_API_KEY=API_KEY
CLOUDINARY_API_SECRET=API_SECRET
CLOUDINARY_FOLDER=visitor-management
SENDGRID_ENABLED=true
SENDGRID_API_KEY=SG.replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@example.com
SENDGRID_FROM_NAME=AccessFlow Security
VISITOR_MAX_ACTIVE_PER_EMPLOYEE=10
VISITOR_PENDING_APPROVAL_TTL_MINUTES=240
VISITOR_EXPIRY_SWEEP_DELAY_MS=60000
NOTIFICATION_EMAIL_RETRY_DELAY_MS=120000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=180
BACKUP_STRATEGY=mongodb-atlas-scheduled-snapshots
BACKUP_RETENTION=managed-by-provider
SWAGGER_UI_ENABLED=false
BACKEND_PUBLIC_URL=https://accessflow-api.onrender.com
FRONTEND_PUBLIC_URL=https://accessflow-web.onrender.com
VISITOR_API_BASE_URL=https://accessflow-api.onrender.com/api/v1
