MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/visitor_management
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
FRONTEND_PUBLIC_URL=https://accessflow-web.onrender.com
CORS_ALLOWED_ORIGINS=https://accessflow-web.onrender.com

CLOUDINARY_CLOUD_NAME=CLOUD_NAME
CLOUDINARY_API_KEY=API_KEY
CLOUDINARY_API_SECRET=API_SECRET

SENDGRID_API_KEY=SG.replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@example.com

# Mobile notification infrastructure. Firebase credentials stay in environment/secrets,
# never in source control. Use either JSON, base64 JSON, or a mounted file path.
PUSH_NOTIFICATIONS_ENABLED=true
EXPO_ACCESS_TOKEN=
FIREBASE_PUSH_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=

SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password

API_BASE_URL=https://accessflow-api-goww.onrender.com/api/v1
# Mobile enterprise release governance
MOBILE_MINIMUM_APP_VERSION=
MOBILE_MINIMUM_RUNTIME_VERSION=
MOBILE_RECOMMENDED_APP_VERSION=
MOBILE_RELEASE_CHANNEL=production
MOBILE_ROLLOUT_COHORT=stable
MOBILE_ROLLOUT_PERCENT=100
MOBILE_FORCED_UPDATE=false
MOBILE_ROLLBACK=false
MOBILE_SUSPICIOUS_CONCURRENT_SESSION_THRESHOLD=4
